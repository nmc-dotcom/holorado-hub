---
import { SITE } from '../consts';
// "홀로라도 ___ ME!!"  — ___ 가 룰렛처럼 바뀜 ("~하 ME" = "~하며 + me" 말장난)
const WORDS = [
  '행복하', '잘살', '든든하', '똑똑하', '맛있', '부지런하',
  '여유롭', '단단하', '따뜻하', '건강하', '알뜰하', '씩씩하',
  '담백하', '넉넉하', '야무지', '홀가분하', '느긋하', '설레',
];
---
<section class="hero">
  <div class="container hero-inner">
    <p class="hero-eyebrow">1인가구 · 요리 · 생산성 · AI 이야기</p>
    <h1 class="hero-title">
      <span class="line1">홀로라도</span>
      <span class="line2">
        <span class="roll" id="roll" aria-live="polite"><span class="roll-word" id="rollWord">행복하</span></span><span class="me">&nbsp;ME!!</span>
      </span>
    </h1>
    <p class="hero-sub">{SITE.tagline}. 혼자 사는 일상을 조금 더 잘, 조금 더 즐겁게.</p>
    <div class="hero-actions">
      <a href="/blog" class="btn">이야기 둘러보기</a>
      <a href="/tools" class="btn btn-ghost">도구 보기</a>
    </div>
  </div>
</section>

<script define:vars={{ WORDS }}>
  const el = document.getElementById('rollWord');
  const wrap = document.getElementById('roll');
  if (el && wrap) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let i = Math.floor(Math.random() * WORDS.length);
    el.textContent = WORDS[i];
    const next = () => {
      i = (i + 1 + Math.floor(Math.random() * (WORDS.length - 1))) % WORDS.length;
      if (reduce) { el.textContent = WORDS[i]; return; }
      wrap.classList.add('rolling-out');
      setTimeout(() => {
        el.textContent = WORDS[i];
        wrap.classList.remove('rolling-out');
        wrap.classList.add('rolling-in');
        setTimeout(() => wrap.classList.remove('rolling-in'), 260);
      }, 220);
    };
    setInterval(next, 2600);
  }
</script>

<style>
  .hero { padding: clamp(40px, 8vw, 96px) 0 clamp(36px, 6vw, 72px); }
  .hero-inner { text-align: center; }
  .hero-eyebrow {
    font-size: clamp(13px, 3.4vw, 15px); font-weight: 700; letter-spacing: 0.02em;
    color: var(--terracotta); margin: 0 0 14px;
  }
  /* 데스크톱: 한 줄 / 모바일: "홀로라도" 윗줄, "___ ME!!" 아랫줄 — 단어와 ME는 항상 붙어있음 */
  .hero-title {
    font-size: clamp(34px, 8.5vw, 76px); line-height: 1.12; margin: 0 0 18px; color: var(--green-deep);
  }
  .hero-title .line1 { display: inline; }
  .hero-title .line2 { display: inline; white-space: nowrap; }  /* ME 절대 안 쪼개짐 */
  .hero-title .line1::after { content: ' '; }
  .me { color: var(--terracotta); white-space: nowrap; }
  .roll { display: inline-block; min-width: 3.2em; text-align: center; color: var(--green-soft); }
  .roll-word { display: inline-block; }
  .rolling-out .roll-word { animation: rollOut .22s ease forwards; }
  .rolling-in .roll-word { animation: rollIn .26s cubic-bezier(.2,.9,.3,1.2) forwards; }
  @keyframes rollOut { to { transform: translateY(-0.5em); opacity: 0; } }
  @keyframes rollIn { from { transform: translateY(0.6em); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  .hero-sub { color: var(--muted); font-size: clamp(14px, 3.6vw, 18px); margin: 0 auto 26px; max-width: 30em; padding: 0 6px; }
  .hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  /* 모바일: "홀로라도"와 "___ ME!!"를 각각 한 줄씩 */
  @media (max-width: 560px) {
    .hero-title .line1, .hero-title .line2 { display: block; }
    .hero-title .line1::after { content: none; }
    .roll { min-width: 0; }
  }
</style>
