---
interface Props { size?: number; withText?: boolean; }
const { size = 34, withText = true } = Astro.props;
---
<a href="/" class="logo" aria-label="홀로라도 홈">
  <svg width={size} height={size} viewBox="0 0 64 64" aria-hidden="true">
    <ellipse cx="32" cy="47" rx="19" ry="6.5" fill="#D8A76B"/>
    <path d="M14 45 Q32 37 50 45 Q50 49 32 50.5 Q14 49 14 45 Z" fill="#3E8E5F"/>
    <path d="M32 45 L32 25" stroke="#2F6B4F" stroke-width="3" stroke-linecap="round"/>
    <path d="M32 32 Q23 28 20 34 Q27 39 32 33 Z" fill="#4CA36E"/>
    <path d="M32 27 Q41 22 45 28 Q38 33 32 28 Z" fill="#57B67C"/>
    <path d="M20 55 Q23.5 53 27 55" stroke="#9BC7DA" stroke-width="2" fill="none" stroke-linecap="round"/>
    <path d="M37 55 Q40.5 53 44 55" stroke="#9BC7DA" stroke-width="2" fill="none" stroke-linecap="round"/>
  </svg>
  {withText && <span class="logo-text serif">홀로라도</span>}
</a>
<style>
  .logo { display: inline-flex; align-items: center; gap: 9px; text-decoration: none !important; }
  .logo-text { font-size: 21px; font-weight: 800; color: var(--green-deep); letter-spacing: -0.02em; }
  .logo:hover .logo-text { color: var(--green); }
</style>
