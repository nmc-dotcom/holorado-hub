---
// 광고 슬롯. ADSENSE.enabled === false 인 동안에는 아무것도 렌더링하지 않습니다.
// 승인 후 consts.ts 의 ADSENSE.enabled = true + slot ID 를 채우면 자동 노출됩니다.
import { ADSENSE } from '../consts';
interface Props { slot?: string; }
const { slot = ADSENSE.slots.inArticle } = Astro.props;
const show = ADSENSE.enabled && ADSENSE.client && slot;
---
{show && (
  <div class="ad-slot">
    <ins class="adsbygoogle"
      style="display:block"
      data-ad-client={ADSENSE.client}
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
)}
