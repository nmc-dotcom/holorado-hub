---
import { CATEGORIES } from '../consts';
interface Props { href: string; title: string; description: string; category: string; pubDate: Date; emoji?: string; }
const { href, title, description, category, pubDate, emoji = '🌱' } = Astro.props;
const cat = CATEGORIES[category] ?? { label: category, color: 'var(--green)' };
const date = pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
---
<a href={href} class="card post-card">
  <div class="thumb" style={`--c:${cat.color}`}><span>{emoji}</span></div>
  <div class="body">
    <span class="badge" style={`background:color-mix(in srgb, ${cat.color} 12%, transparent); color:${cat.color}`}>{cat.label}</span>
    <h3 class="title">{title}</h3>
    <p class="desc">{description}</p>
    <span class="date">{date}</span>
  </div>
</a>
<style>
  .post-card { display: flex; flex-direction: column; overflow: hidden; text-decoration: none !important; height: 100%; }
  .thumb { height: 104px; display: grid; place-items: center; background: color-mix(in srgb, var(--c) 14%, var(--paper)); }
  .thumb span { font-size: 42px; }
  @media (max-width: 560px) {
    .thumb { height: 84px; }
    .thumb span { font-size: 36px; }
    .title { font-size: 18px; }
  }
  .body { padding: 18px 20px 20px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .title { font-size: 19px; color: var(--green-deep); margin: 2px 0; line-height: 1.35; }
  .desc { font-size: 14px; color: var(--muted); margin: 0; line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .date { font-size: 12.5px; color: var(--muted); margin-top: auto; padding-top: 6px; }
</style>
