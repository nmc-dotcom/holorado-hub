---
interface Props { name: string; desc: string; url: string; emoji: string; status: string; icon?: string; }
const { name, desc, url, emoji, status, icon } = Astro.props;
const soon = status === 'soon';
const Tag = soon ? 'div' : 'a';
---
<Tag class:list={['card tool-card', { soon }]} {...(!soon ? { href: url, rel: 'noopener' } : {})}>
  <div class="ic">
    {icon === 'pdf' ? (
      <svg viewBox="0 0 40 40" width="30" height="30" aria-hidden="true">
        <path d="M10 5 L25 5 L31 11 L31 35 L10 35 Z" fill="#FBF8F0" stroke="#234E3A" stroke-width="2.5" stroke-linejoin="round"/>
        <path d="M25 5 L25 11 L31 11 Z" fill="#E3CE9E" stroke="#234E3A" stroke-width="2.5" stroke-linejoin="round"/>
        <path d="M20 16 L20 20 M17 19 L20 22 L23 19" stroke="#C96F4A" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M20 30 L20 26 M17 27 L20 24 L23 27" stroke="#2F6B4F" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    ) : emoji}
  </div>
  <div class="meta">
    <div class="row">
      <h3 class="name">{name}</h3>
      {status === 'live' && <span class="live">사용 가능</span>}
      {soon && <span class="soonbadge">준비 중</span>}
    </div>
    <p class="desc">{desc}</p>
    {!soon && <span class="go">바로가기 →</span>}
  </div>
</Tag>
<style>
  .tool-card { display: flex; gap: 16px; padding: 20px 22px; align-items: flex-start; text-decoration: none !important; }
  .tool-card.soon { opacity: 0.65; cursor: default; }
  .tool-card.soon:hover { transform: none; box-shadow: var(--shadow); }
  .ic { font-size: 32px; width: 54px; height: 54px; flex: none; display: grid; place-items: center;
    background: var(--cream-deep); border-radius: 16px; }
  .row { display: flex; align-items: center; gap: 10px; }
  .name { margin: 0; font-size: 18px; color: var(--green-deep); }
  .live { font-size: 11.5px; font-weight: 700; color: #fff; background: var(--green); padding: 2px 9px; border-radius: 999px; }
  .soonbadge { font-size: 11.5px; font-weight: 700; color: var(--muted); background: var(--sand); padding: 2px 9px; border-radius: 999px; }
  .desc { margin: 6px 0 8px; font-size: 14px; color: var(--muted); line-height: 1.6; }
  .go { font-size: 14px; font-weight: 700; color: var(--terracotta); }
</style>
