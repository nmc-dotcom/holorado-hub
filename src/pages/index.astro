---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroRoulette from '../components/HeroRoulette.astro';
import PostCard from '../components/PostCard.astro';
import ToolCard from '../components/ToolCard.astro';
import { TOOLS } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);
---
<BaseLayout>
  <HeroRoulette />

  <section class="container block">
    <div class="head">
      <div>
        <p class="eyebrow">최근 이야기</p>
        <h2 class="section-title">혼자 사는 데 도움이 되는 이야기</h2>
      </div>
      <a href="/blog" class="btn btn-ghost">전체 보기</a>
    </div>
    <div class="grid">
      {posts.map((p) => (
        <PostCard href={`/blog/${p.id}`} title={p.data.title} description={p.data.description}
          category={p.data.category} pubDate={p.data.pubDate} emoji={p.data.heroEmoji} />
      ))}
    </div>
  </section>

  <svg class="torn-strip" viewBox="0 0 1200 30" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0 14 L38 10 L61 16 L105 8 L144 15 L190 9 L228 17 L276 11 L318 18 L370 9 L412 16 L455 12 L503 19 L548 10 L597 16 L642 8 L688 15 L735 11 L781 18 L829 9 L874 16 L921 12 L969 18 L1013 10 L1058 16 L1101 9 L1146 15 L1200 11 L1200 21 L1152 25 L1104 19 L1057 24 L1009 18 L962 24 L913 20 L866 25 L818 19 L771 24 L723 20 L676 25 L629 18 L582 24 L534 20 L487 25 L440 19 L393 24 L345 20 L298 25 L251 18 L204 24 L157 20 L110 25 L63 19 L30 23 L0 20 Z" fill="#DCD2B6" opacity="0.8"/>
  </svg>

  <section class="container block tools-block">
    <div class="tools-intro">
      <p class="eyebrow">홀로라도가 만든 것</p>
      <h2 class="section-title">쓸모 있는 도구, 무료로</h2>
      <p class="tools-desc">업무나 일상에 도움이 되는 작은 도구들을 만들어 나눕니다. 회원가입 없이, 파일을 서버에 올리지 않고 안전하게.</p>
    </div>
    <div class="tools-grid">
      {TOOLS.map((t) => (
        <ToolCard name={t.name} desc={t.desc} url={t.url} emoji={t.emoji} status={t.status} />
      ))}
    </div>
  </section>
</BaseLayout>
<style>
  .block { padding: 20px 0; }
  .head { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; margin-bottom: 24px; }
  @media (max-width: 560px) {
    .head { flex-direction: column; align-items: flex-start; gap: 12px; }
    .block { padding: 14px 0; }
  }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 22px; }
  .tools-block { margin-top: 36px; }
  .tools-intro { text-align: center; max-width: 560px; margin: 0 auto 26px; }
  .tools-desc { color: var(--muted); font-size: 15px; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 18px; max-width: 760px; margin: 0 auto; }
</style>
