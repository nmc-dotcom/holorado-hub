---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import { CATEGORIES } from '../consts';

interface Props {
  title: string; description: string; category: string; pubDate: Date; emoji?: string;
}
const { title, description, category, pubDate, emoji = '🌱' } = Astro.props;
const cat = CATEGORIES[category] ?? { label: category, color: 'var(--green)' };
const date = pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={title} description={description}>
  <article class="post">
    <div class="read">
      <a href="/blog" class="back">← 이야기 목록</a>
      <div class="post-head">
        <span class="badge" style={`background:color-mix(in srgb, ${cat.color} 12%, transparent); color:${cat.color}`}>{cat.label}</span>
        <h1>{emoji} {title}</h1>
        <p class="lead">{description}</p>
        <span class="date">{date}</span>
      </div>

      <div class="prose">
        <slot />
      </div>

      <!-- 본문 하단 광고 (승인 후 자동 노출) -->
      <AdSlot />

      <div class="post-foot">
        <a href="/blog" class="btn btn-ghost">다른 이야기 보기</a>
        <a href="/tools" class="btn">홀로라도 도구 →</a>
      </div>
    </div>
  </article>
</BaseLayout>
<style>
  .post { padding: 40px 0 20px; }
  .back { font-weight: 700; font-size: 14px; color: var(--muted); }
  .back:hover { color: var(--green); }
  .post-head { margin: 20px 0 30px; }
  .post-head h1 { font-size: clamp(28px, 5vw, 42px); line-height: 1.25; color: var(--green-deep); margin: 12px 0 10px; }
  .post-head .lead { font-size: 17px; color: var(--muted); margin: 0 0 10px; }
  .post-head .date { font-size: 13px; color: var(--muted); }
  .prose :global(h2) { font-size: 24px; color: var(--green-deep); margin: 40px 0 12px; padding-left: 12px; border-left: 4px solid var(--green-soft); }
  .prose :global(h3) { font-size: 19px; color: var(--green-deep); margin: 28px 0 8px; }
  .prose :global(p) { font-size: 16.5px; line-height: 1.85; margin: 0 0 16px; }
  .prose :global(ul), .prose :global(ol) { font-size: 16.5px; line-height: 1.85; padding-left: 22px; }
  .prose :global(li) { margin-bottom: 7px; }
  .prose :global(strong) { color: var(--green); font-weight: 700; }
  .prose :global(a) { color: var(--terracotta); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(blockquote) { margin: 20px 0; padding: 14px 20px; background: var(--cream-deep);
    border-radius: 12px; border-left: 4px solid var(--terracotta); color: var(--ink); }
  .prose :global(code) { background: var(--cream-deep); padding: 2px 7px; border-radius: 6px; font-size: 0.9em; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 18px 0; font-size: 15px; }
  .prose :global(th), .prose :global(td) { border: 1px solid var(--line); padding: 10px 12px; text-align: left; }
  .prose :global(th) { background: var(--cream-deep); color: var(--green-deep); }
  .post-foot { display: flex; gap: 12px; flex-wrap: wrap; justify-content: space-between; margin-top: 40px; padding-top: 26px; border-top: 1px solid var(--line); }
</style>

<script>
  // 페이지가 로드되었을 때 실행 (Astro ViewTransitions를 쓰신다면 'astro:page-load' 이벤트를 사용해도 좋습니다)
  function initCopyButtons() {
    const codeBlocks = document.querySelectorAll('pre');

    codeBlocks.forEach((codeBlock) => {
      // 이미 버튼이 붙어있다면 중복 생성 방지
      if (codeBlock.querySelector('.copy-button')) return;

      // 1. 버튼 요소 만들기
      const button = document.createElement('button');
      button.className = 'copy-button';
      button.type = 'button';
      button.innerText = '복사';

      // 2. 코드 블록에 버튼 붙이기
      codeBlock.appendChild(button);

      // 3. 클릭 시 복사 기능 이벤트 연결
      button.addEventListener('click', async () => {
        const codeElement = codeBlock.querySelector('code');
        const textToCopy = codeElement ? codeElement.innerText : '';

        try {
          // 클립보드로 텍스트 복사
          await navigator.clipboard.writeText(textToCopy);
          
          // 버튼 상태를 '완료!'로 변경
          button.innerText = '완료!';
          button.classList.add('copied');

          // 2초 후에 다시 원래대로 복구
          setTimeout(() => {
            button.innerText = '복사';
            button.classList.remove('copied');
          }, 2000);
        } catch (err) {
          console.error('복사에 실패했습니다:', err);
          button.innerText = '실패';
        }
      });
    });
  }

  // 실행
  initCopyButtons();
  // 혹시 모를 페이지 전환(View Transitions) 대응
  document.addEventListener('astro:page-load', initCopyButtons);
</script>
